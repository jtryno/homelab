global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - "/etc/prometheus/alert.rules.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "alertmanager:9093"

scrape_configs:
  - job_name: "node_exporter"
    static_configs:
      - targets:
{% for host in groups['all'] %}
          - "{{ hostvars[host]['ansible_host'] }}:9100"
{% endfor %}
